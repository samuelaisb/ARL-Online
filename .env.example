# Required for reservation notification emails (server starts without it; emails fail until set)
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=your@email.com
# Optional — reservation emails fall back to EMAIL_TO when unset
# RESERVE_INVENTORY_EMAIL_TO=your@email.com
# Optional — Slack workflow trigger webhook for new reservations (text variables only)
# SLACK_RESERVATION_WEBHOOK_URL=https://hooks.slack.com/triggers/...
PORT=3000

# Supabase — server + runtime client auth via GET /config.js (primary path for the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API=your-anon-key
# Optional Vite build-time aliases (Docker/Cloud Build build args, or npm run dev:client without Express)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server only — never expose to the browser or Docker build args)
# Required for inventory + reservations. Apply supabase/migrations/001_inventory.sql first.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL for Supabase email-confirmation redirects (baked into production builds).
# Omit locally to use the current origin (e.g. http://localhost:5173). Also add this URL
# under Supabase → Authentication → URL Configuration (Site URL + Redirect URLs).
SITE_URL=https://activistresourcelibrary.com

# Optional — Plausible analytics domain (injects script + allows CSP when set)
# PLAUSIBLE_DOMAIN=activistresourcelibrary.com
